module QuadFunction where

import Daml.Script

quadFunction : Int -> Int -> Int -> Int
quadFunction x y z = 3 * x * x + 2 * y + z

testQuadFunction : Script ()
testQuadFunction = script do
  debug (quadFunction 1 2 3)

testLambdaFunction : Script ()
testLambdaFunction = script do
  let quadLambda = \x y z -> 3 * x * x + 2 * y + z
  debug (quadLambda 1 2 3)
